# App
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# Database
DATABASE_URL="postgresql://vielhome:vielhome@localhost:5432/vielhome?schema=public"

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_LENGTH=5
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5

# Rate limiting (21_ADRs > ADR-061 — now actually enforced via APP_GUARD,
# previously registered but inert)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
# Stricter override for POST /auth/otp/request specifically (see
# AuthController's @Throttle decorator, which duplicates this default as a
# literal since decorators can't read ConfigService at compile time).
THROTTLE_OTP_LIMIT=5

# CORS (21_ADRs > ADR-061)
# Comma-separated allowlist, e.g. https://app.vielhome.com,https://admin.vielhome.com
# Leave empty for local/dev (permissive). REQUIRED when NODE_ENV=production —
# main.ts refuses to boot with wide-open CORS in production.
CORS_ORIGINS=

# Object storage (21_ADRs > ADR-087) — S3/MinIO-compatible, real presigned
# upload/download for Documents. Leave any of the four below empty and
# StorageService.isConfigured() is false: the upload-url endpoint refuses
# with a clear error, and downloads fall back to their pre-ADR-087 behavior
# (return the stored value as-is) — nothing breaks with this section unset.
# These defaults match docker-compose.yml's own `minio` service exactly —
# `docker-compose up -d` + this file as-is is a working local setup with no
# further changes.
STORAGE_ENDPOINT=localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=vielhome-documents
STORAGE_ACCESS_KEY_ID=vielhome
STORAGE_SECRET_ACCESS_KEY=vielhome-dev-secret
# MinIO needs path-style (bucket in the URL path, not the hostname) —
# true is correct for docker-compose.yml's own `minio` service. Set to
# false only when pointing at real AWS S3 (virtual-hosted style).
STORAGE_FORCE_PATH_STYLE=true
# docker-compose.yml's own `minio` service runs plain HTTP on :9000 (no
# local TLS cert) — false matches it. Set true for real AWS S3 or any
# MinIO deployment behind HTTPS.
STORAGE_USE_SSL=false

# Notification providers (21_ADRs > ADR-088) — real Push/Email/SMS
# delivery for Notifications, plus real SMS for OTP delivery
# (AuthService.requestOtp). Each block below is independently optional —
# leave any one channel's vars empty and that channel falls back to its
# pre-ADR-088 log-stub behavior; the three channels don't depend on each
# other. Unlike Documents' MinIO (self-hostable via docker-compose), these
# are real third-party accounts this sandbox has never had — testing the
# real dispatch path requires the user's own SendGrid/Twilio/Firebase
# credentials.

# Email — SendGrid (https://sendgrid.com), a disclosed vendor pick; no
# source document names one. Get an API key from Settings > API Keys.
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=VielHome

# SMS — Twilio (https://twilio.com), a disclosed vendor pick; no source
# document names one. Account SID + Auth Token from the Twilio Console
# dashboard; From Number must be a Twilio-provisioned sending number.
SMS_PROVIDER_ACCOUNT_SID=
SMS_PROVIDER_AUTH_TOKEN=
SMS_PROVIDER_FROM_NUMBER=

# Push — Firebase Cloud Messaging, the vendor 19_Current_Sprint's own
# "Planned additions" line has named since Sprint 12. Create a service
# account under Firebase Console > Project Settings > Service Accounts >
# Generate New Private Key, then take projectId/client_email/private_key
# from the downloaded JSON. PUSH_FIREBASE_PRIVATE_KEY must keep its
# newlines escaped as literal \n (paste the PEM as one line) — the app
# unescapes them back into real newlines at boot.
PUSH_FIREBASE_PROJECT_ID=
PUSH_FIREBASE_CLIENT_EMAIL=
PUSH_FIREBASE_PRIVATE_KEY=
